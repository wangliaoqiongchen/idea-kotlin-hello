for循环
fun main() {
    val range = 1..5
    for (i in range) println("hello world $i")
}
stop用法可以跳i
fun main() {
    for (i in 1..10 step 2 ) println("hello world $i")
}
downTo用法，倒数 后还可加stop跳数
fun main() {
    for (i in 10 downTo 1 step 2) {
        println("hello world $i")
    }
}
for里套for
会先执行一次外1+内123完再外2+内123完外3+内123结束
fun main() {
    for (i in 1..3)
        for (j in 1..3)
            print("外层$i,内层$j \n")

}
continue可以跳过这个if里的东西
fun main() {
    for (i in 1..10){
        if(i == 5)continue
        println("当前$i")
    }
}
break可以跳过后面所有，直接结束for循环
fun main() {
    for (i in 1..10){
        if(i == 5)break
        println("当前$i")
    }
}
continue只会就近for来执行
fun main() {
    for (i in 1..3){
        for (j in 1..3){
            if (i == j)continue
            println("$i $j")
        }
    }
}
如果想要外部也continue需要加xxx@和@xxx  如下
fun main() {
    xxx@ for (i in 1..3){
         for (j in 1..3){
            if (i == j)continue@xxx
            println("$i $j")
        }
    }
}
