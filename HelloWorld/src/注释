when的用法

fun main() {
    val c = 'B'
    when (c){
        'A' -> println("尖子")
        'B' -> println("平行")
        'C' -> println("深造")
    }
}
两种方法

fun main() {
    val c = 'B'
    val value = when (c){
        'A' -> 1
        'B' -> 2
        'C' -> 3
        else -> 0
    }
    println(value)
}

fun main() {
   var score = 99
    val grade = when(score) {
        in 90..100 -> "优秀"
        in 80..89 -> "良好"
        in 70..79 -> "及格"
        in 60..69 -> "神"
        else -> "不及格"
    }
    println(grade)
}
