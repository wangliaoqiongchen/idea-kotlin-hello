fun main() {
    var score = 99
    if (score >=90)
        println("优秀")
    else if (score >= 70) //当上一级if判断失败时，会继续判断这一级
        println("良好")
    else if (score >= 60)
        println("及格")
    else            //没有if后为最后一次，进入else造句中
        println("不及格")
}

